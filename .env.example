# LocalMind Configuration
# Copy this to .env and fill in your values

# ── Telegram ──────────────────────────────────────────
TELEGRAM_TOKEN=your_bot_token_here

# Your Telegram group/chat ID
ALLOWED_CHAT_ID=your_chat_id_here

# Topic thread IDs
TOPIC_SCHEDULE=0
TOPIC_TUTOR=0
TOPIC_STUDY=0
TOPIC_GENERAL=0

# ── LMS — pick ONE (Canvas or Schoology) ──────────────

# Canvas (recommended — easier setup)
# Get your token: Canvas → Account → Settings → New Access Token
CANVAS_TOKEN=
CANVAS_DOMAIN=canvas.instructure.com

# Schoology (alternative)
# Get your keys: yourschool.schoology.com/api
SCHOOLOGY_KEY=
SCHOOLOGY_SECRET=
SCHOOLOGY_DOMAIN=app.schoology.com

# ── Ollama ────────────────────────────────────────────
# Pull first: ollama pull phi3:mini (low RAM)
# or:         ollama pull llama3.1:8b (better, needs 8GB+)
OLLAMA_MODEL=phi3:mini
OLLAMA_URL=http://localhost:11434
